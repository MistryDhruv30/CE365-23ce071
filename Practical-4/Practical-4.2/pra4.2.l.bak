%{
#include <stdio.h>
#include <string.h>

char line[1000];
%}

%%

[Cc][Hh][Aa][Rr][Uu][Ss][Aa][Tt]    { printf("university"); }

.    { printf("%s", yytext); }

\n   { printf("\n"); }

